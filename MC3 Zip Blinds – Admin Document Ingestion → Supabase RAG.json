      "parameters": {
        "jsCode": "// Validate and extract metadata from the admin upload request\nconst body = $input.first().json.body || $input.first().json;\nconst category = body.category || 'General Knowledge';\nconst model = body.model || 'All Models';\nconst uploadedAt = new Date().toISOString();\nconst source = 'admin-upload';\n\n// Pass binary data along with metadata\nconst binaryData = $input.first().binary || {};\nconst fileKeys = Object.keys(binaryData);\n\nif (fileKeys.length === 0) {\n  throw new Error('No file found in upload request');\n}\n\nreturn [{\n  json: { category, model, uploadedAt, source, fileKeys },\n  binary: binaryData\n}];"
      },
